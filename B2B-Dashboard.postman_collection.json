{
  "info": {
    "name": "B2B Executive Dashboard API",
    "description": "Multi-tenant B2B e-commerce backend (Laravel 12). Run **Login** first — it captures the Sanctum token into the `token` collection variable, which every authenticated request reuses automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "order_id", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.token) {",
                  "    pm.collectionVariables.set('token', body.token);",
                  "    console.log('Saved token to collection variable.');",
                  "}",
                  "pm.test('token issued', () => pm.expect(body.token).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "login"]
            },
            "description": "Authenticates and returns a Sanctum token. The test script stores it in `{{token}}`."
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Dashboard",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('has data + cached flag', () => {",
                  "    pm.expect(body).to.have.property('data');",
                  "    pm.expect(body).to.have.property('generated_at');",
                  "    pm.expect(body).to.have.property('cached');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/analytics/dashboard",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "analytics", "dashboard"]
            },
            "description": "Cached 1h, stampede-protected, rate-limited 200/min per business. Returns revenue, AOV, top products, and 24h hourly velocity."
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Generate a fresh idempotency key unless one is already pinned.",
                  "if (!pm.collectionVariables.get('idempotency_key')) {",
                  "    pm.collectionVariables.set('idempotency_key', pm.variables.replaceIn('{{$guid}}'));",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body.order && body.order.id) {",
                  "    pm.collectionVariables.set('order_id', body.order.id);",
                  "}",
                  "pm.test('order is pending', () => pm.expect(body.order.status).to.eql('pending'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotency_key}}",
                "description": "Optional. Retrying with the same key within 24h replays the original response."
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"product_id\": 1, \"quantity\": 2 }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/orders",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "orders"]
            },
            "description": "Creates a pending order. business_id is taken from the authenticated user, never from the body."
          }
        },
        {
          "name": "List Orders (cursor paginated)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/orders?cursor=",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "orders"],
              "query": [
                { "key": "cursor", "value": "", "description": "Pass the `next_cursor` from a previous response to page forward." }
              ]
            },
            "description": "Returns only the current business's orders. Response includes `next_cursor`."
          }
        },
        {
          "name": "Update Order Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"paid\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/orders/{{order_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "orders", "{{order_id}}", "status"]
            },
            "description": "Transitions: pending → paid → processing → shipped → delivered. `canceled` from any non-terminal state. Validated against the OrderStatus enum."
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Payment Webhook",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"payment_succeeded\",\n  \"order_id\": {{order_id}},\n  \"transaction_id\": \"txn-{{$timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/webhooks/payment",
              "host": ["{{base_url}}"],
              "path": ["webhooks", "payment"]
            },
            "description": "Public endpoint. Idempotent on `transaction_id`; out-of-order events are logged and ignored gracefully."
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Reports database / cache / queue connectivity. 200 when healthy, 500 otherwise."
          }
        }
      ]
    }
  ]
}